# Unity text assets stay diffable (force-text serialization) — never LFS these
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.asmdef text eol=lf
*.cs text eol=lf
*.shader text eol=lf
*.json text eol=lf
*.inputactions text eol=lf

# Binary assets via Git LFS
*.fbx filter=lfs diff=lfs merge=lfs -text
*.FBX filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
